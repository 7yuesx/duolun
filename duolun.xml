<mujoco>
    <compiler angle="radian" autolimits="true"/>
    <option timestep="0.001" gravity ="0 0 -9.81" wind="0 0 0" integrator="RK4"/>
    <visual> 
        <global realtime="1"/>
        <quality shadowsize="16384" numslices="28" offsamples="4" />
        <headlight diffuse="1 1 1" specular="0.5 0.5 0.5" active="1" />
        <rgba fog="0 1 0 1" haze="1 0 0 1"/>
    </visual>
    <default>
        
    </default>
    <asset>
        <mesh name="tetrahedron" vertex="0 0 0 1 0 0 0 1 0 0 0 1" />
        <!-- <mesh file="card.obj" /> -->
        <!-- <texture type="2d" file="./king_of_clubs.png" /> -->
        <!-- <material name="king_of_clubs" texture="king_of_clubs" /> -->
        <!-- <hfield name="agent_eval_gym" file="agent_eval_gym.png" size="10 10 1 1" /> -->
        <!-- <texture type="skybox" file="../asset/desert.png"
            gridsize="3 4" gridlayout=".U..LFRB.D.." /> -->
        <texture name="plane" type="2d" builtin="checker" rgb1=".1 .1 .1" rgb2=".9 .9 .9" 
            width="512" height="512" mark="cross" markrgb=".8 .8 .8" />
        <material name="plane" reflectance="0.3" texture="plane" texrepeat="1 1" texuniform="true"/>
        <material name="box" rgba="0 0.5 0 1"  emission="0"/>
    </asset>
    <!-- <worldbody>
        <geom type="plane" size="10 10 0.1"/>
        <body name="chassis" pos="0 0 0.1 "> 
            <geom type="cylinder" pos="0 0 0" size="0.2 0.005" rgba="0.2 0.2 0.2 1"/>
        </body>
    </worldbody>
    -->
    <worldbody>
        <geom type="plane" size="10 10 0.1" material="plane" friction="1.0 0.005 0.0001"/>
        <body name="gimbal" pos="0 0 0.3">
            <joint type="free"/>
            <geom name="gimbal_geom1" type="box" size="0.14 0.14 0.135" pos="0 0 0" rgba="1.0 0.8 0.0 1"/>
            <geom name="gimbal_geom2" type="box" size="0.065 0.15 0.065" pos="0 0.145 0" rgba="1.0 0.647 0.0 1"/>
            <site name="imu" type="box" size=".01 .01 .01"/>
            <body name="chassis" pos="0 0 -0.135">
                <!-- 正方形底盘几何体：边长0.5，厚度0.1 -->
                <joint name="joint_Yaw" type="hinge" axis="0 0 1" damping="0.01"/>
                <geom name="chassis_geom" type="box" size="0.28 0.28 0.025" pos="0 0 0.015" rgba="1.0 0.8 0.0 1"/>
                <site name="imu_chassis" type="box" size=".01 .01 .01"/>
                <!-- 前左舵轮 -->
                <body name="steer1" pos="-0.205 0.205 0.0175">
                    <joint name="joint_steer1" type="hinge" axis="0 0 1"  damping="0.01"/>
                    <geom name="front_left_steering_geom" type="cylinder" size="0.015 0.0025" pos="0 0 -0.03" rgba="0.8 0.6 0.3 1"/>
                    
                    <body name="wheel1" pos="0 0 -0.0875">
                        <joint name="joint_wheel1" type="hinge" pos="0 0 -0.02" axis="0 1 0" damping="0.01"/>
                        <geom name="front_left_wheel_geom" type="cylinder" size="0.075 0.015" pos="0 0 -0.02" quat="0.707 0.707 0 0" friction="0.7 0.005 0.0001" rgba="1.0  0.4 0.0 1"/>
                    </body>
                </body>
                
                <!-- 前右舵轮 -->
                <body name="steer2" pos="-0.205 -0.205 0.0175">
                    <joint name="joint_steer2" type="hinge" axis="0 0 1"  damping="0.01"/>
                    <geom name="front_right_steering_geom" type="cylinder" size="0.015 0.0025" pos="0 0 -0.03" rgba="0.8 0.6 0.3 1"/>
                    
                    <body name="wheel2" pos="0 0 -0.0875">
                        <joint name="joint_wheel2" type="hinge" pos="0 0 -0.02" axis="0 1 0" damping="0.01"/>
                        <geom name="front_right_wheel_geom" type="cylinder" size="0.075 0.015" pos="0 0 -0.02" quat="0.707 0.707 0 0" friction="0.7 0.005 0.0001" rgba="1.0  0.4 0.0 1"/>
                    </body>
                </body>
                
                <!-- 后右舵轮 -->
                <body name="steer3" pos="0.205 -0.205 0.0175">
                    <joint name="joint_steer3" type="hinge" axis="0 0 1"  damping="0.01"/>
                    <geom name="rear_right_steering_geom" type="cylinder" size="0.015 0.0025" pos="0 0 -0.03" rgba="0.8 0.6 0.3 1"/>
                    
                    <body name="wheel3" pos="0 0 -0.0875">
                        <joint name="joint_wheel3" type="hinge" pos="0 0 -0.02" axis="0 1 0" damping="0.01"/>
                        <geom name="rear_right_wheel_geom" type="cylinder" size="0.075 0.015" pos="0 0 -0.02" quat="0.707 0.707 0 0" friction="0.7 0.005 0.0001" rgba="1.0  0.4 0.0 1"/>
                    </body>
                </body>

                <!-- 后左舵轮 -->
                <body name="steer4" pos="0.205 0.205 0.0175">
                    <joint name="joint_steer4" type="hinge" axis="0 0 1"  damping="0.01"/>
                    <geom name="rear_left_steering_geom" type="cylinder" size="0.015 0.0025" pos="0 0 -0.03" rgba="0.8 0.6 0.3 1"/>
            
                    <body name="wheel4" pos="0 0 -0.0875">
                        <joint name="joint_wheel4" type="hinge" pos="0 0 -0.02" axis="0 1 0" damping="0.01"/>
                        <geom name="rear_left_wheel_geom" type="cylinder" size="0.075 0.015" pos="0 0 -0.02" quat="0.707 0.707 0 0" friction="0.7 0.005 0.0001" rgba="1.0  0.4 0.0 1"/>
                    </body>
                </body>
                

            </body>
        </body>    
    </worldbody>
    <actuator>
       
        <motor joint="joint_steer1" name="motor_steer1" gear="1" forcelimited="true" forcerange="-2 2"/>
        <motor joint="joint_steer2" name="motor_steer2" gear="1" forcelimited="true" forcerange="-2 2"/>
        <motor joint="joint_steer3" name="motor_steer3" gear="1" forcelimited="true" forcerange="-2 2"/>
        <motor joint="joint_steer4" name="motor_steer4" gear="1" forcelimited="true" forcerange="-2 2"/>
        <motor joint="joint_wheel1" name="motor_wheel1" gear="1" forcelimited="true" forcerange="-2 2"/>
        <motor joint="joint_wheel2" name="motor_wheel2" gear="1" forcelimited="true" forcerange="-2 2"/>
        <motor joint="joint_wheel3" name="motor_wheel3" gear="1" forcelimited="true" forcerange="-2 2"/>
        <motor joint="joint_wheel4" name="motor_wheel4" gear="1" forcelimited="true" forcerange="-2 2"/>

         <motor joint="joint_Yaw" name="motor_Yaw" forcerange="-50 50"/>
    </actuator>
    <sensor>

        <framequat name="orientation" objtype="site" objname="imu"/>
        <gyro name="imu_gyro" site="imu"/>
        <framequat name="imu_chassis" objtype="site" objname="imu_chassis"/>

        <jointpos joint="joint_Yaw" name="pos_Yaw"/>
        <jointpos joint="joint_steer1" name="pos_steer1"/>
        <jointpos joint="joint_steer2" name="pos_steer2"/>
        <jointpos joint="joint_steer3" name="pos_steer3"/>
        <jointpos joint="joint_steer4" name="pos_steer4"/>
        <jointpos joint="joint_wheel1" name="pos_wheel1"/>
        <jointpos joint="joint_wheel2" name="pos_wheel2"/>
        <jointpos joint="joint_wheel3" name="pos_wheel3"/>
        <jointpos joint="joint_wheel4" name="pos_wheel4"/>
               
        <jointpos joint="joint_Yaw" name="vel_Yaw"/>       
        <jointvel joint="joint_steer1" name="vel_steer1"/>
        <jointvel joint="joint_steer2" name="vel_steer2"/>
        <jointvel joint="joint_steer3" name="vel_steer3"/>
        <jointvel joint="joint_steer4" name="vel_steer4"/>
        <jointvel joint="joint_wheel1" name="vel_wheel1"/>
        <jointvel joint="joint_wheel2" name="vel_wheel2"/>
        <jointvel joint="joint_wheel3" name="vel_wheel3"/>
        <jointvel joint="joint_wheel4" name="vel_wheel4"/>

    </sensor>
</mujoco>